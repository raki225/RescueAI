{
  "name": "rescueai-backend",
  "version": "1.0.0",
  "description": "RescueAI — Emergency Medical Triage Assistant (Backend API)",
  "private": true,
  "type": "commonjs",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "serve": "node dist/server.js",
    "seed": "tsx src/data/seed.ts",
    "test": "jest --runInBand",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "emergency",
    "triage",
    "healthtech",
    "ai",
    "gemini"
  ],
  "author": "RescueAI",
  "license": "MIT",
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "joi": "^17.13.3",
    "mongoose": "^8.6.0",
    "winston": "^3.14.2"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.5.0",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}
