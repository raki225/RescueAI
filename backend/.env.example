# ─────────────────────────────────────────────────────────────
#  RescueAI Backend — Environment Template
#  Copy this file to `.env` and fill in values.
# ─────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=4000
HOST=127.0.0.1

# CORS — frontend dev origin
CLIENT_ORIGIN=http://localhost:5180

# MongoDB connection string (local or Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/rescueai

# Google Gemini AI (optional — app falls back to rule-based engine if empty)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# Google Maps Platform (optional — server-side key).
# Enables Google Geocoding, Reverse Geocoding, Places Nearby/Autocomplete,
# Directions and Distance Matrix. Leave EMPTY to use the built-in, key-less
# OpenStreetMap engine (Nominatim + Overpass). The app works fully either way.
GOOGLE_MAPS_API_KEY=

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info
