# Frontend environment (Vite). Requests are proxied to the backend in dev,
# so the default relative base URL works out of the box.
VITE_API_BASE_URL=/api/v1

# ── Google Maps (optional) ───────────────────────────────────────────────────
# Paste your browser key (Maps JavaScript API) here to enable Google-powered
# maps, Places Autocomplete, geocoding and directions on the client.
#
#   VITE_GOOGLE_MAPS_API_KEY=YOUR_KEY
#
# Leave it EMPTY to run on the built-in OpenStreetMap fallback — every feature
# still works. This is a referrer-restricted browser key, not a secret.
VITE_GOOGLE_MAPS_API_KEY="AIzaSyDmUjcNUom1awEe85m7iRp22qadJmvRg3Y"

# NOTE: There is intentionally NO default map centre. RescueAI never assumes a
# city — location comes from GPS, reverse-geocoding, or manual PIN/area/city
# search, so it works anywhere in India.
