# ─────────────────────────────────────────────────────────────
#  RescueAI Frontend — Environment Template (Vite)
#  Copy this file to `.env` and fill in values.
# ─────────────────────────────────────────────────────────────

# API base URL. In dev, requests are proxied to the backend, so the default
# relative path works out of the box.
VITE_API_BASE_URL=/api/v1

# Google Maps browser key (Maps JavaScript API). Optional.
# Paste your key to enable Google-powered maps, Places Autocomplete, geocoding
# and directions on the client:
#
#   VITE_GOOGLE_MAPS_API_KEY=YOUR_KEY
#
# Leave EMPTY to use the built-in OpenStreetMap fallback — every feature still
# works. This is a referrer-restricted browser key, not a secret.
VITE_GOOGLE_MAPS_API_KEY=
